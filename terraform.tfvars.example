# ─── Required (only 1!) ───────────────────────────────────────────────────────

# Name prefix applied to all resources. Lowercase alphanumeric or hyphens, ≤20 chars.
name = "freetier"

# ─── Optional — notifications ────────────────────────────────────────────────

# notification_email = "you@example.com"  # Email for SNS alerts and Budgets notifications
                                           # You will receive a confirmation email — click the link to activate

# ─── Optional — identity / access ────────────────────────────────────────────

# aws_region  = "us-east-1"    # us-east-1 has the broadest free plan coverage
# db_username = "dbadmin"      # RDS / Aurora master username (password is auto-generated)
# key_name    = null           # EC2 key pair for SSH; null = use SSM Session Manager
# my_ip_cidr  = null           # Your public IP in CIDR for SSH (only needed with key_name)
                                # Find yours: curl -s https://checkip.amazonaws.com | awk '{print $1"/32"}'

# ─── Optional — networking ───────────────────────────────────────────────────

# vpc_cidr = "10.0.0.0/16"   # VPC CIDR block — default /16 provides room for 256 /24 subnets
# az_count = 2               # Number of availability zones (2–4)

# ─── Optional — free-plan size overrides ──────────────────────────────────────
# All defaults are at the free-plan maximum. Increasing any value may incur charges.

# ec2_instance_type     = "t4g.micro"      # t-family only; t4g.micro is free-plan eligible
# ec2_volume_size_gb    = 30               # <= 30 GB to stay within free plan EBS allowance
# rds_instance_class    = "db.t4g.micro"   # db.t3.micro or db.t4g.micro only
# rds_allocated_storage = 20               # <= 20 GB to stay within free plan storage
# aurora_min_capacity   = 0.5              # >= 0.5 ACUs (platform minimum)
# aurora_max_capacity   = 4.0              # <= 4.0 ACUs (free plan cap)
# lambda_memory_mb      = 128              # <= 128 MB to maximize free GB-seconds
# elasticache_node_type = "cache.t3.micro" # only free-plan eligible node type
# log_retention_days    = 7                # must be a valid CloudWatch retention value

# ─── Optional — feature toggles ───────────────────────────────────────────────
# Core services (VPC, EC2, Lambda, S3, DynamoDB, SQS, SNS, IAM, CloudWatch,
# Budgets) are always created. Omit features entirely to enable all defaults.

# features = {
#   rds             = true
#   aurora          = true
#   elasticache     = true
#   cloudfront      = true
#   cognito         = true
#   step_functions  = true
#   bedrock_logging = true
# }

# Example — credit-saver stack (Aurora free, skip RDS + cache):
# features = {
#   rds             = false
#   aurora          = true
#   elasticache     = false
#   cloudfront      = true
#   cognito         = true
#   step_functions  = true
#   bedrock_logging = true
# }
